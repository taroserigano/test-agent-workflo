{
  "name": "todo-api",
  "version": "1.0.0",
  "description": "Simple Todo REST API demo with GitHub Actions + Agentic Workflows",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "jest --coverage",
    "lint": "eslint src/**/*.js tests/**/*.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
